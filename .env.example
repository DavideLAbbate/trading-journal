# ===========================================
# Environment Variables for Trading Journal
# ===========================================
# Copy this file to .env.local and fill in your values

# Cesium Token (for 3D globe visualization)
VITE_CESIUM_TOKEN=your_cesium_token_here

# Backend API Base URL
VITE_API_BASE_URL=http://localhost:3000/api

# ===========================================
# NEWS API Configuration
# ===========================================
# Get your free API key at: https://newsapi.org/register
# Note: Free tier works only from localhost/dev, not production
VITE_NEWS_API_KEY=your_newsapi_key_here

# ===========================================
# LOCAL LLM Configuration (Ollama)
# ===========================================
# Default Ollama endpoint (change if running on different port/host)
VITE_LLM_BASE_URL=http://localhost:11434

# Your local model name (run `ollama list` to see available models)
# Examples:
#   - llama3.2
#   - mistral
#   - wizard-vicuna-uncensored:30b-q4_K_M
#   - codellama
VITE_LLM_MODEL=wizard-vicuna-uncensored:30b-q4_K_M

# ===========================================
# IMPORTANT: Running Ollama with CORS
# ===========================================
# To allow browser access to Ollama, start it with:
#
# Linux/Mac:
#   OLLAMA_ORIGINS=* ollama serve
#
# Windows (CMD):
#   set OLLAMA_ORIGINS=* && ollama serve
#
# Windows (PowerShell):
#   $env:OLLAMA_ORIGINS="*"; ollama serve
