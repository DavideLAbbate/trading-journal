# Cesium Ion Access Token
# Get a free token at: https://cesium.com/ion/tokens
VITE_CESIUM_TOKEN=your_cesium_ion_token_here

# API Configuration
VITE_API_BASE_URL=/api

# Local LLM Configuration
# Default: Ollama (http://localhost:11434)
# Also compatible with: LM Studio, LocalAI, text-generation-webui
VITE_LLM_BASE_URL=http://localhost:11434
VITE_LLM_MODEL=llama3.2
